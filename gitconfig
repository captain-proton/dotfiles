[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[color]
    ui = true

[delta]
    navigate = true  # use n and N to move between diff sections
    side-by-side = true

[merge]
    tool = meld

[alias]
    lol = log --pretty=oneline --graph --decorate --abbrev-commit --all

[push]
    default = matching

[include]
    path = ~/.gitconfig.local

[remote "origin"]
    prune = true

[pull]
    rebase = false

[init]
    defaultBranch = main
