# ANSIBLE MANAGED

[Desktop Entry]
Name=Custom VS Code
Comment=Code Editing. Redefined.
GenericName=Text Editor
{% if vscode_password_store is defined %}
Exec=/usr/bin/code --password-store="{{ __vscode_password_store }}" %F
{% else %}
Exec=/usr/bin/code %F
{% endif %}
Icon=vscode
Type=Application
StartupNotify=false
StartupWMClass=Code
Categories=TextEditor;Development;IDE;
MimeType=application/x-code-workspace;
Actions=new-empty-window;
Keywords=vscode;

[Desktop Action new-empty-window]
Name=New Empty Window
Name[cs]=Nové prázdné okno
Name[de]=Neues leeres Fenster
Name[es]=Nueva ventana vacía
Name[fr]=Nouvelle fenêtre vide
Name[it]=Nuova finestra vuota
Name[ja]=新しい空のウィンドウ
Name[ko]=새 빈 창
Name[ru]=Новое пустое окно
Name[zh_CN]=新建空窗口
Name[zh_TW]=開新空視窗
{% if vscode_password_store is defined %}
Exec=/usr/bin/code --password-store="{{ __vscode_password_store }}" --new-window %F
{% else %}
Exec=/usr/bin/code --new-window %F
{% endif %}
Icon=vscode
